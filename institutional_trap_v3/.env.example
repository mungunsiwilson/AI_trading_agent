# Platform Selection: 'binance' or 'deriv'
TRADING_PLATFORM=deriv

# For Binance Futures (leave empty if using Deriv)
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET_KEY=your_binance_secret_key_here
EXCHANGE_TESTNET=true

# For Deriv (required if TRADING_PLATFORM=deriv)
DERIV_APP_ID=1089
DERIV_SERVER=ws.binaryws.com

# MT5 Configuration (for Windows automation with Deriv)
MT5_ENABLED=true
# Optional: Auto-login to MT5 (leave empty for manual login in MT5 terminal)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=Deriv-Demo
MAGIC_NUMBER=123456
DEVIATION_POINTS=10

# Machine Learning Configuration
ML_ENABLED=true
ML_MIN_TRADES_FOR_TRAINING=20
ML_MIN_PROBABILITY_THRESHOLD=0.55
ML_AUTO_RETRAIN=true
ML_RETRAIN_EVERY_N_TRADES=10

# Trading Configuration
SYMBOL=R_25
POSITION_SIZE_USD=100
TIME_LIMIT_MINUTES=240
MAX_POSITIONS=1
TRADING_MODE=BOTH

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging
LOG_LEVEL=INFO
