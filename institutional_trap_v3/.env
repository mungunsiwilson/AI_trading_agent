# --- TRADING CONFIGURATION ---
TRADING_PLATFORM=deriv
SYMBOL=Volatility 25 Index
POSITION_SIZE_LOTS=1.0
MAX_POSITIONS=1
TRADING_MODE=BOTH

# --- DERIV MT5 CREDENTIALS ---
