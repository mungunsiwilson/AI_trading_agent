# Use "Deriv-Server" for real accounts

# Telegram Notifications
TELEGRAM_BOT_TOKEN=8071126440:AAHfdjKH_q7xW52oma-9u6JUIOGFQqiCOCE
TELEGRAM_CHAT_ID=5155525489
TELEGRAM_NOTIFY_ON_ENTRY = true                        # Send notification on entry
TELEGRAM_NOTIFY_ON_EXIT = true                          # Send notification on exit
TELEGRAM_NOTIFY_ON_ERROR = true                         # Send notification on errors
TELEGRAM_NOTIFY_ON_BREAKEVEN = true                     # Send notification when stop moves to breakeven
TELEGRAM_NOTIFY_ON_STOP_UPDATE = true                  # Send notification on trailing stop updates

# --- STRATEGY PARAMETERS (SMC 3-TF) ---
# Timeframes (in seconds for MT5)
TF_1H=3600
TF_5M=300
TF_1M=60

# Risk Management
SL_BUFFER_POINTS=1      # Points beyond sweep wick
USE_TRAILING_STOP=True
TRAIL_ACTIVATION_R=1.0    # Activate trail after 1R profit
TRAIL_DISTANCE_R=0.5      # Trail distance is 0.5R

# Pattern Confirmation
MIN_BODY_RATIO=0.70       # Body > 70% of range for engulfing
MIN_WICK_RATIO=0.60       # Wick > 60% of range for pinbar

# Machine Learning
ML_ENABLED=True
ML_MODEL_PATH=model.pkl
ML_TRADE_DB=trades.db
ML_RETRAIN_INTERVAL=10
ML_MIN_TRADES_TO_ACTIVATE=20
ML_CONFIDENCE_THRESHOLD=0.45

MAX_ENTRIES_PER_SETUP = 3
ENTRY_COOLDOWN_SEC = 60